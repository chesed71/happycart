app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Env files (anon key는 비밀이 아니지만 환경별로 별도 관리)
# .env.test은 service_role 키를 담고 있어 절대 커밋 금지 — Flutter asset에도 등록하지 않음
.env
.env.development
.env.staging
.env.production
.env.test
# .env.example 은 커밋 가능 (예외)
!.env.example

