# 파이프라인 환경 변수 템플릿. 복사해서 .env로 쓰고 실제 값을 채운다.
#   cp .env.example .env
# .env는 .gitignore 대상 (자격증명 커밋 금지).

# ── 로컬 Docker postgres (파이프라인 작업 DB) ──────────────────────────────────
# docker run 시 POSTGRES_PASSWORD/POSTGRES_DB로 설정한 값.
HAPPYCART_PG_CONTAINER=happycart-pg
HAPPYCART_PG_DB=happycart
HAPPYCART_PG_USER=postgres
HAPPYCART_PG_PASSWORD=happycart
HAPPYCART_PG_HOST=localhost
HAPPYCART_PG_PORT=54322
# Python 파이프라인이 TCP로 접속하는 DSN (위 값에서 조합).
HAPPYCART_DSN=postgresql://postgres:happycart@localhost:54322/happycart

# ── 운영 Supabase (Phase 3 운영 반영 단계에서만 사용) ─────────────────────────
# service_role 키는 RLS를 우회한다 — 절대 커밋하지 말 것.
# SUPABASE_DB_URL=postgresql://postgres:<password>@db.ftgsnvvskbadegswvjnp.supabase.co:5432/postgres
# SUPABASE_SERVICE_ROLE_KEY=
